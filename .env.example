# === PRODUCTION (Vercel + Neon) ===
# Ces variables sont à configurer dans Vercel → Settings → Environment Variables

# Connection poolée (pour Prisma en production)
DATABASE_URL="postgresql://user:pass@ep-xxx.region.neon.tech/rnaslut-db?sslmode=require&pgbouncer=true"

# Connection directe (pour l'adapter Neon serverless)
DIRECT_URL="postgresql://user:pass@ep-xxx.region.neon.tech/rnaslut-db?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generez-avec: openssl rand -base64 32"
NEXTAUTH_URL="https://votre-domaine.com"

# === LOCAL (développement) ===
# DATABASE_URL="postgresql://user:pass@localhost:5432/rnaslut?schema=public"
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="secret-local-pour-dev"